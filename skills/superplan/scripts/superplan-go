#!/usr/bin/env bash
# superplan-go — headless runner for the compiled /goal.
# Reads $SUPERPLAN_ROOT/GOAL.txt (default .superplan/GOAL.txt), runs
# `claude -p "/goal …"`, tees to $SUPERPLAN_ROOT/run.log, spawns a
# stuck-watcher sidecar. Exits non-zero on failure, timeout, or stuck-loop.
#
# Env:
#   SUPERPLAN_ROOT                Artifact directory (default: .superplan)
#                                 Set by dispatchers like Superboard to point
#                                 at a task-specific subdirectory.
#   CLAUDE_BIN                    Path to claude CLI (default: claude)
#   SUPERPLAN_MAX_RUNTIME         Hard kill after N seconds (default: 7200)
#   SUPERPLAN_STUCK_MINUTES       Stuck threshold in minutes (default: 15)
#   SUPERPLAN_STUCK_WATCHER       Set to 0 to disable the watcher (default: 1)
#   SUPERPLAN_ALLOW_LONG_COMMANDS Comma-separated list of long-running commands
#                                 that should NOT trigger the stuck-watcher.
#                                 See stuck-watcher.mjs for the default list.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SUPERPLAN_ROOT="${SUPERPLAN_ROOT:-.superplan}"
export SUPERPLAN_ROOT
GOAL_FILE="$SUPERPLAN_ROOT/GOAL.txt"
LOG_FILE="$SUPERPLAN_ROOT/run.log"
STUCK_PID_FILE="$SUPERPLAN_ROOT/stuck-watcher.pid"
RUNNER_PID_FILE="$SUPERPLAN_ROOT/runner.pid"
TIMEOUT_PID_FILE="$SUPERPLAN_ROOT/timeout.pid"

MAX_RUNTIME_SECONDS="${SUPERPLAN_MAX_RUNTIME:-7200}"
STUCK_MINUTES="${SUPERPLAN_STUCK_MINUTES:-15}"
STUCK_WATCHER_ENABLED="${SUPERPLAN_STUCK_WATCHER:-1}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"

# Pre-flight ---------------------------------------------------------------

if [ ! -f "$GOAL_FILE" ]; then
  echo "superplan-go: $GOAL_FILE missing. Run /superplan first." >&2
  exit 2
fi

GOAL_CONTENT="$(cat "$GOAL_FILE")"
GOAL_LEN=${#GOAL_CONTENT}

if [ "$GOAL_LEN" -gt 4000 ]; then
  echo "superplan-go: GOAL.txt is $GOAL_LEN chars; max is 4000. Aborting." >&2
  exit 2
fi
if [ "$GOAL_LEN" -lt 80 ]; then
  echo "superplan-go: GOAL.txt looks too short ($GOAL_LEN chars). Aborting." >&2
  exit 2
fi

# Strip leading "/goal " if present so we can re-emit it cleanly.
GOAL_BODY="${GOAL_CONTENT#/goal }"

if ! command -v "$CLAUDE_BIN" >/dev/null 2>&1; then
  echo "superplan-go: $CLAUDE_BIN not on PATH. Set CLAUDE_BIN env var or install Claude Code." >&2
  exit 2
fi

if [ "$STUCK_WATCHER_ENABLED" = "1" ] && ! command -v node >/dev/null 2>&1; then
  echo "superplan-go: node not on PATH but stuck-watcher requires it." >&2
  echo "superplan-go: install Node, or set SUPERPLAN_STUCK_WATCHER=0 to disable the watcher." >&2
  exit 2
fi

mkdir -p "$(dirname "$LOG_FILE")"

# Cleanup ------------------------------------------------------------------

cleanup() {
  local code=${1:-0}
  for pidfile in "$STUCK_PID_FILE" "$RUNNER_PID_FILE" "$TIMEOUT_PID_FILE"; do
    if [ -f "$pidfile" ]; then
      pid=$(cat "$pidfile" 2>/dev/null || echo "")
      if [ -n "$pid" ]; then
        kill "$pid" 2>/dev/null || true
      fi
      rm -f "$pidfile"
    fi
  done
  exit "$code"
}
trap 'cleanup 130' INT
trap 'cleanup 143' TERM

# Run ----------------------------------------------------------------------

{
  echo "superplan-go: starting at $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "superplan-go: max runtime ${MAX_RUNTIME_SECONDS}s, stuck threshold ${STUCK_MINUTES}m"
  echo "superplan-go: stuck-watcher enabled: $STUCK_WATCHER_ENABLED"
  echo "superplan-go: claude binary $CLAUDE_BIN"
  echo "superplan-go: goal length ${GOAL_LEN}/4000 chars"
  echo "----"
} | tee "$LOG_FILE"

# Spawn stuck-watcher sidecar (Node, multi-signal)
if [ "$STUCK_WATCHER_ENABLED" = "1" ]; then
  node "$SCRIPT_DIR/stuck-watcher.mjs" --minutes="$STUCK_MINUTES" --parent-pid="$$" &
  echo $! > "$STUCK_PID_FILE"
fi

# Run claude headless; tee output to log
( "$CLAUDE_BIN" -p "/goal $GOAL_BODY" 2>&1 | tee -a "$LOG_FILE" ) &
RUNNER_PID=$!
echo $RUNNER_PID > "$RUNNER_PID_FILE"

# Hard runtime cap
(
  sleep "$MAX_RUNTIME_SECONDS"
  if kill -0 "$RUNNER_PID" 2>/dev/null; then
    echo "superplan-go: max runtime reached, killing child" | tee -a "$LOG_FILE"
    kill -TERM "$RUNNER_PID" 2>/dev/null || true
  fi
) &
echo $! > "$TIMEOUT_PID_FILE"

# Wait for the runner
set +e
wait "$RUNNER_PID"
RUNNER_CODE=$?
set -e

case "$RUNNER_CODE" in
  0)
    echo "superplan-go: completed (exit 0)" | tee -a "$LOG_FILE"
    cleanup 0
    ;;
  130)
    echo "superplan-go: interrupted by user" | tee -a "$LOG_FILE"
    cleanup 130
    ;;
  137|143)
    echo "superplan-go: child killed (timeout or stuck-watcher)" | tee -a "$LOG_FILE"
    cleanup 3
    ;;
  *)
    echo "superplan-go: child exited $RUNNER_CODE" | tee -a "$LOG_FILE"
    cleanup "$RUNNER_CODE"
    ;;
esac
