<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Superplan — {{TASK_TITLE}}</title>
<style>
  :root {
    color-scheme: dark;
    --bg: #0b0c10;
    --panel: #14161d;
    --panel-2: #1a1d27;
    --text: #e6e8ee;
    --muted: #8b91a3;
    --accent: #7c9cff;
    --accent-2: #b08cff;
    --ok: #66e0a3;
    --warn: #f0c264;
    --err: #ff7a7a;
    --border: #262a36;
    --code-bg: #0e1017;
    --radius: 14px;
    --shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 8px 24px rgba(0,0,0,0.35);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: radial-gradient(1200px 600px at 80% -10%, rgba(124,156,255,0.10), transparent 60%),
                radial-gradient(900px 500px at -10% 110%, rgba(176,140,255,0.08), transparent 60%),
                var(--bg);
    color: var(--text);
    font: 15px/1.55 -apple-system, BlinkMacSystemFont, "SF Pro Text", "Inter", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    padding: 48px 24px 96px;
  }
  .wrap { max-width: 920px; margin: 0 auto; }
  .header {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-bottom: 24px;
  }
  .badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 4px 10px; border: 1px solid var(--border);
    border-radius: 999px; background: var(--panel);
    color: var(--muted); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase;
  }
  .badge::before { content: ""; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  h1 {
    font-size: 28px; line-height: 1.2; margin: 0 0 6px;
    background: linear-gradient(180deg, #fff, #b9c2dd);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .subtitle { color: var(--muted); margin: 0 0 28px; }
  .toc {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 8px; margin-bottom: 28px;
  }
  .toc a {
    display: block; padding: 10px 12px; border: 1px solid var(--border);
    background: var(--panel); border-radius: 10px;
    color: var(--text); text-decoration: none; font-size: 13px;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }
  .toc a:hover { border-color: var(--accent); background: var(--panel-2); transform: translateY(-1px); }
  .toc a .count { color: var(--muted); font-size: 11px; margin-left: 6px; }
  section.card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 22px 24px;
    margin: 0 0 18px;
  }
  section.card > h2:first-child { margin-top: 0; }
  h2 {
    font-size: 18px; margin: 24px 0 12px;
    display: flex; align-items: center; gap: 10px;
  }
  h2::before {
    content: ""; width: 8px; height: 8px; border-radius: 2px;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
  }
  h3 { font-size: 15px; margin: 18px 0 8px; color: var(--text); }
  p, li { color: var(--text); }
  a { color: var(--accent); }
  ul, ol { padding-left: 22px; }
  li { margin: 4px 0; }
  hr { border: 0; border-top: 1px solid var(--border); margin: 18px 0; }
  blockquote {
    margin: 12px 0; padding: 10px 14px;
    border-left: 3px solid var(--accent-2);
    background: var(--panel-2); color: var(--muted);
    border-radius: 0 10px 10px 0;
  }
  code {
    background: var(--code-bg); padding: 2px 6px; border-radius: 6px;
    border: 1px solid var(--border); font-size: 13px;
    font-family: ui-monospace, "JetBrains Mono", Menlo, Consolas, monospace;
  }
  pre {
    background: var(--code-bg); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 16px; overflow-x: auto;
    font-size: 13px; line-height: 1.5;
  }
  pre code { background: transparent; border: 0; padding: 0; }
  table { width: 100%; border-collapse: collapse; margin: 8px 0 16px; font-size: 13px; }
  th, td { padding: 8px 10px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; }
  th { color: var(--muted); font-weight: 600; }
  .checklist li { list-style: none; position: relative; padding-left: 24px; }
  .checklist li::before {
    content: ""; position: absolute; left: 0; top: 4px;
    width: 14px; height: 14px; border: 1.5px solid var(--border);
    border-radius: 4px; background: var(--code-bg);
  }
  .checklist li.done::before {
    background: var(--ok); border-color: var(--ok);
    box-shadow: inset 0 0 0 2px var(--code-bg);
  }
  .goal-box {
    background: linear-gradient(180deg, rgba(124,156,255,0.10), rgba(176,140,255,0.08));
    border: 1px solid rgba(124,156,255,0.35);
    padding: 18px 20px; border-radius: 12px; margin-top: 18px;
  }
  .goal-box .copy-row { display: flex; gap: 10px; align-items: center; margin-top: 12px; }
  .copy-btn {
    border: 1px solid var(--border); background: var(--panel);
    color: var(--text); padding: 6px 12px; border-radius: 8px; cursor: pointer; font-size: 13px;
  }
  .copy-btn:hover { border-color: var(--accent); }
  .meta {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px; margin-bottom: 12px;
  }
  .meta .kv {
    padding: 10px 12px; border: 1px solid var(--border); border-radius: 10px; background: var(--panel-2);
  }
  .meta .kv .k { color: var(--muted); font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; }
  .meta .kv .v { font-weight: 600; margin-top: 2px; }
  footer { color: var(--muted); font-size: 12px; text-align: center; margin-top: 36px; }
</style>
</head>
<body>
<div class="wrap">

  <div class="header">
    <span class="badge">Superplan · Draft</span>
    <span class="badge" id="ts">{{RENDERED_AT}}</span>
  </div>

  <h1>{{TASK_TITLE}}</h1>
  <p class="subtitle">{{TASK_SUBTITLE}}</p>

  <div class="meta">
    <div class="kv"><div class="k">Stack</div><div class="v">{{STACK}}</div></div>
    <div class="kv"><div class="k">Type</div><div class="v">{{TASK_TYPE}}</div></div>
    <div class="kv"><div class="k">Phases</div><div class="v">{{PHASE_COUNT}}</div></div>
    <div class="kv"><div class="k">Max turns</div><div class="v">{{MAX_TURNS}}</div></div>
  </div>

  <div class="toc">
    <a href="#plan">Plan</a>
    <a href="#acceptance">Acceptance</a>
    <a href="#verify">Verify</a>
    <a href="#risks">Risks</a>
    <a href="#polish">Polish</a>
    <a href="#state">State</a>
    <a href="#lock">Lock</a>
    <a href="#goal">/goal</a>
  </div>

  <section class="card" id="plan">
    <h2>Plan</h2>
    <div>{{PLAN_HTML}}</div>
  </section>

  <section class="card" id="acceptance">
    <h2>Acceptance criteria</h2>
    <div>{{ACCEPTANCE_HTML}}</div>
  </section>

  <section class="card" id="verify">
    <h2>Verification commands</h2>
    <div>{{VERIFY_HTML}}</div>
  </section>

  <section class="card" id="risks">
    <h2>Risks</h2>
    <div>{{RISKS_HTML}}</div>
  </section>

  <section class="card" id="polish">
    <h2>Polish passes</h2>
    <div>{{POLISH_HTML}}</div>
  </section>

  <section class="card" id="state">
    <h2>State (live ledger during execution)</h2>
    <div>{{STATE_HTML}}</div>
  </section>

  <section class="card" id="lock">
    <h2>Lock <span class="badge" style="margin-left:8px;{{LOCK_BADGE_STYLE}}">{{LOCK_STATUS}}</span></h2>
    {{LOCK_HTML}}
  </section>

  <section class="card" id="goal">
    <h2>Compiled /goal</h2>
    <p>Paste this into your Claude Code session to start, or run <code>scripts/superplan-go</code> headless.</p>
    <div class="goal-box">
      <pre id="goal-text"><code>{{GOAL_TEXT}}</code></pre>
      <div class="copy-row">
        <button class="copy-btn" onclick="(async()=>{try{await navigator.clipboard.writeText(document.getElementById('goal-text').innerText);this.textContent='Copied';setTimeout(()=>this.textContent='Copy /goal',1200);}catch(e){this.textContent='Copy failed';}})()">Copy /goal</button>
        <span style="color:var(--muted); font-size:12px;">{{GOAL_CHAR_COUNT}} / 4000 chars</span>
      </div>
    </div>
  </section>

  <footer>Rendered by superplan · refresh this page after the agent edits the plan.</footer>
</div>
</body>
</html>
